   "source": [
    "select city, sum(casualties) as total_casualties\n",
    "from default.road_accidents_dataset\n",
    "where (select sum(casualties) from default.road_accidents_dataset) > 100\n",
    "group by city\n",
    "order by total_casualties desc\n",
    "limit 5"
   ]
  }
